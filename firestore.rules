rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User product lists: owner can read/write, anyone can read (for share links)
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Share codes: anyone can look up a code, only authenticated users can create/delete
    match /shareCodes/{code} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
